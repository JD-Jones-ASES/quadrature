{
  "id": "freefall-throw-up",
  "title": "A ball thrown straight up",
  "topic": "freefall",
  "slug": "throw-up",
  "scenario": "A ball leaves your hand at 20 m/s straight up, from a height of 1.5 m. How high does it go, when does it land, and how fast is it moving when it hits the ground?",
  "regime": 1,
  "constants": {
    "g": -10
  },
  "initial_conditions": {
    "x0": 1.5,
    "v0": 20
  },
  "assumptions": [
    {
      "claim": "No air resistance (the ball is in free fall under gravity alone).",
      "kind": "model"
    },
    {
      "claim": "g = -10 m/s^2, a clean-arithmetic simplification of -9.81 m/s^2.",
      "kind": "model"
    },
    {
      "claim": "The ball is a point mass; its size and spin are ignored.",
      "kind": "model"
    }
  ],
  "algebra": {
    "steps": [
      {
        "label": "Assert the constant-acceleration relations",
        "latex": "v = v_0 + a t \\qquad x = x_0 + v_0 t + \\tfrac{1}{2} a t^2",
        "prose": "These are the formulas the algebra-based course memorizes. (They are quadratures — we will see them fall out of the calculus.)"
      },
      {
        "label": "Apex: the top is where velocity is zero",
        "latex": "v = 0 \\;\\implies\\; t_{\\text{apex}} = - \\frac{v_{0}}{a}",
        "prose": "Velocity is zero only for an instant — but acceleration is not. The ball is still being pulled down at g."
      },
      {
        "label": "Maximum height from the timeless equation",
        "latex": "0 = v_0^2 + 2a\\,(x - x_0) \\;\\implies\\; x_{\\max} = x_{0} - \\frac{v_{0}^{2}}{2 a}",
        "prose": "Set v = 0 in v² = v₀² + 2a(x − x₀). No time needed — this is the equation an algebra student is handed without its derivation."
      },
      {
        "label": "Time of flight: solve for when it returns to the ground",
        "latex": "x_0 + v_0 t + \\tfrac{1}{2} a t^2 = 0 \\;\\implies\\; t_{\\text{flight}} = \\frac{- v_{0} - \\sqrt{- 2 a x_{0} + v_{0}^{2}}}{a}",
        "prose": "The physical (later) root of the quadratic — the moment it lands."
      },
      {
        "label": "Impact velocity at the ground",
        "latex": "v_{\\text{impact}} = - \\sqrt{- 2 a x_{0} + v_{0}^{2}}",
        "prose": "Negative because it is moving downward at impact (up is positive)."
      }
    ],
    "result": {
      "apex_time": {
        "label": "Time to the apex",
        "unit": "s",
        "symbolic_latex": "- \\frac{v_{0}}{a}",
        "value": 2.0,
        "display": "2"
      },
      "max_height": {
        "label": "Maximum height",
        "unit": "m",
        "symbolic_latex": "x_{0} - \\frac{v_{0}^{2}}{2 a}",
        "value": 21.5,
        "display": "21.5"
      },
      "flight_time": {
        "label": "Time of flight",
        "unit": "s",
        "symbolic_latex": "\\frac{- v_{0} - \\sqrt{- 2 a x_{0} + v_{0}^{2}}}{a}",
        "value": 4.073644,
        "display": "4.074"
      },
      "impact_velocity": {
        "label": "Velocity at impact",
        "unit": "m/s",
        "symbolic_latex": "- \\sqrt{- 2 a x_{0} + v_{0}^{2}}",
        "value": -20.736441,
        "display": "-20.74"
      }
    }
  },
  "calculus": {
    "steps": [
      {
        "label": "Start from the acceleration",
        "latex": "a(t) = a",
        "prose": "Constant — the only force acting is gravity. On the stacked graph this is a flat line."
      },
      {
        "label": "Velocity is the integral of acceleration",
        "latex": "v(t) = \\int a \\, dt = v_0 + a t",
        "prose": "The constant of integration is v₀ (the velocity at t = 0). The slope of the v–t graph is a; the area under the a–t graph is the change in v."
      },
      {
        "label": "Position is the integral of velocity",
        "latex": "x(t) = \\int v \\, dt = \\int (v_0 + a t)\\, dt = x_0 + v_0 t + \\tfrac{1}{2} a t^2",
        "prose": "The constant of integration is x₀. The slope of the x–t graph is v; the area under the v–t graph is the change in x."
      },
      {
        "label": "The algebra formula has emerged",
        "latex": "\\boxed{\\,x = x_0 + v_0 t + \\tfrac{1}{2} a t^2\\,}",
        "prose": "This is exactly the formula the algebra course memorizes — here it is the integral with the integrand (a) frozen to a constant. Freeze the integrand and the integral becomes multiply-and-add. That is the algebra.",
        "emphasis": true
      }
    ]
  },
  "equivalence_proof": {
    "checked_by": "sympy",
    "holds": true,
    "detail": "simplify(algebra - calculus) == 0 for each identity below",
    "checks": [
      {
        "key": "v_formula_is_integral",
        "claim": "The algebra velocity formula v = v₀ + at IS the integral ∫a dt with v(0)=v₀.",
        "holds": true,
        "tier": "structural"
      },
      {
        "key": "x_formula_is_integral",
        "claim": "The algebra position formula x = x₀ + v₀t + ½at² IS the integral ∫v dt with x(0)=x₀.",
        "holds": true,
        "tier": "structural"
      },
      {
        "key": "apex_is_v_zero",
        "claim": "Velocity really is zero at the apex time (so the apex time is correct).",
        "holds": true,
        "tier": "structural"
      },
      {
        "key": "max_height_agrees",
        "claim": "Max height from the timeless equation equals the calculus trajectory at its apex.",
        "holds": true,
        "tier": "structural"
      },
      {
        "key": "flight_time_lands",
        "claim": "At the flight time the calculus trajectory really returns to the ground (so the time is correct).",
        "holds": true,
        "tier": "structural"
      },
      {
        "key": "impact_velocity_agrees",
        "claim": "Impact velocity from the timeless equation equals the calculus velocity at landing.",
        "holds": true,
        "tier": "structural"
      }
    ]
  },
  "units_check": {
    "checked_by": "sympy",
    "holds": true
  },
  "sign_analysis": {
    "rule": "speeding up ⟺ sign(v·a) > 0; slowing down ⟺ sign(v·a) < 0",
