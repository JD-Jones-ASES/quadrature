    },
    {
      "source": "em-bfield-wire",
      "target": "em-lorentz-force",
      "type": "related-to",
      "gloss": "this field exerts the force qvB on nearby moving charges"
    },
    {
      "source": "em-bfield-wire",
      "target": "em-flux",
      "type": "related-to",
      "gloss": "integrating B over an area gives the flux"
    },
    {
      "source": "em-capacitance",
      "target": "em-capacitor-energy",
      "type": "related-to",
      "gloss": "the charge–voltage relation whose area is the stored energy"
    },
    {
      "source": "em-capacitance",
      "target": "em-rc-time-constant",
      "type": "related-to",
      "gloss": "with a resistor, RC sets how fast it charges"
    },
    {
      "source": "em-capacitor-energy",
      "target": "em-capacitance",
      "type": "related-to",
      "gloss": "uses Q = CV; the energy is the area under V(q) = q/C"
    },
    {
      "source": "em-capacitor-energy",
      "target": "en-spring-pe",
      "type": "related-to",
      "gloss": "the same ½(stiffness)(displacement)² shape as a spring — energy is a triangle's area"
    },
    {
      "source": "em-coulomb",
      "target": "grav-newton",
      "type": "related-to",
      "gloss": "the same inverse-square form as gravitation, with charge in place of mass"
    },
    {
      "source": "em-coulomb",
      "target": "em-efield-point",
      "type": "related-to",
      "gloss": "the force per unit charge is the field, F = qE"
    },
    {
      "source": "em-efield-point",
      "target": "em-potential-point",
      "type": "related-to",
      "gloss": "the field is minus the gradient of the potential, E = −dV/dr"
    },
    {
      "source": "em-flux",
      "target": "em-motional-emf",
      "type": "related-to",
      "gloss": "a changing flux drives an EMF (Faraday's law)"
    },
    {
      "source": "em-flux",
      "target": "em-bfield-wire",
      "type": "related-to",
      "gloss": "B is the field whose flux this is"
    },
    {
      "source": "em-lorentz-force",
      "target": "em-wire-force",
      "type": "related-to",
      "gloss": "summed over the moving charges in a current, this becomes F = BIL"
    },
    {
      "source": "em-lorentz-force",
      "target": "em-bfield-wire",
      "type": "related-to",
      "gloss": "B is the field a current produces"
    },
    {
      "source": "em-motional-emf",
      "target": "em-flux",
      "type": "related-to",
      "gloss": "Faraday's law: EMF = −dΦ/dt; sweeping area at rate Lv gives EMF = BLv"
    },
    {
      "source": "em-motional-emf",
      "target": "drag-v-of-t",
      "type": "related-to",
      "gloss": "in an RL/RC circuit the induced quantities approach their final values exponentially, like a velocity under drag"
    },
    {
      "source": "em-ohms-law",
      "target": "em-power-electric",
      "type": "related-to",
      "gloss": "combine with P = IV to get P = I²R = V²/R"
    },
    {
      "source": "em-potential-energy",
      "target": "en-work",
      "type": "related-to",
      "gloss": "the work done against the Coulomb force, ∫F dr — the area under the force–distance curve"
    },
    {
      "source": "em-potential-energy",
      "target": "em-coulomb",
      "type": "related-to",
      "gloss": "its slope is the Coulomb force, −dU/dr = F"
    },
    {
      "source": "em-potential-point",
      "target": "em-potential-energy",
      "type": "related-to",
      "gloss": "the potential energy per unit test charge, U = qV"
    },
    {
      "source": "em-potential-point",
      "target": "grav-newton",
      "type": "related-to",
      "gloss": "like gravitation, the 1/r potential is the convergent integral of an inverse-square field"
    },
    {
      "source": "em-power-electric",
      "target": "en-power",
      "type": "related-to",
      "gloss": "the same power = energy/time, here electrical"
    },
    {
      "source": "em-power-electric",
      "target": "em-ohms-law",
      "type": "related-to",
      "gloss": "substitute V = IR to get the resistor forms I²R and V²/R"
    },
    {
      "source": "em-rc-time-constant",
      "target": "drag-v-of-t",
      "type": "related-to",
      "gloss": "the same exponential approach as a velocity under linear drag — RC plays the role of the mechanical time constant"
    },
    {
      "source": "em-rc-time-constant",
      "target": "em-capacitance",
      "type": "related-to",
      "gloss": "sets the e-folding time for charging the capacitance C"
    },
    {
      "source": "em-wire-force",
      "target": "em-lorentz-force",
      "type": "related-to",
      "gloss": "the Lorentz force qvB summed over the charge carriers in the current"
    },
    {
      "source": "en-kinetic",
      "target": "mom-momentum",
      "type": "related-to",
      "gloss": "both built from mass and velocity (K = p²/2m)"
    },
    {
      "source": "en-mech-energy",
      "target": "en-kinetic",
      "type": "related-to",
      "gloss": "the ½mv² term — the kinetic part"
    },
    {
      "source": "en-mech-energy",
      "target": "en-work",
      "type": "related-to",
      "gloss": "conservation is the first integral of F=ma: ½mv² is the work done, ∫F dx"
    },
    {
