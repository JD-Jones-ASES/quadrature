      "id": "drag-terminal",
      "name": "Terminal velocity (linear drag)",
      "domain": "mechanics",
      "regime": 2,
      "lhs": "v_{\\text{term}}",
      "expr": "m*g/b",
      "expr_srepr": "Mul(Pow(Symbol('b', real=True), Integer(-1)), Symbol('g', real=True), Symbol('m', real=True))",
      "latex": "v_{\\text{term}} = \\frac{g m}{b}",
      "result_unit": "m/s",
      "variables": {
        "m": {
          "unit": "kg",
          "desc": "mass"
        },
        "g": {
          "unit": "m/s**2",
          "desc": "gravitational acceleration (negative, up positive)"
        },
        "b": {
          "unit": "kg/s",
          "desc": "linear drag coefficient"
        }
      },
      "assumptions": [
        "drag linear in speed",
        "constant gravity"
      ],
      "derivation": null,
      "lessons": [
        "freefall-drag"
      ],
      "citations": [],
