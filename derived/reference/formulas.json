    {
      "id": "drag-v-of-t",
      "name": "Velocity under linear drag",
      "domain": "mechanics",
      "regime": 2,
      "lhs": "v",
      "expr": "(m*g/b) + (v0 - m*g/b)*exp(-b*t/m)",
      "expr_srepr": "Add(Mul(Add(Symbol('v0', real=True), Mul(Integer(-1), Pow(Symbol('b', real=True), Integer(-1)), Symbol('g', real=True), Symbol('m', real=True))), exp(Mul(Integer(-1), Symbol('b', real=True), Pow(Symbol('m', real=True), Integer(-1)), Symbol('t', real=True)))), Mul(Pow(Symbol('b', real=True), Integer(-1)), Symbol('g', real=True), Symbol('m', real=True)))",
      "latex": "v = \\left(v_{0} - \\frac{g m}{b}\\right) e^{- \\frac{b t}{m}} + \\frac{g m}{b}",
      "result_unit": "m/s",
      "variables": {
        "m": {
          "unit": "kg",
          "desc": "mass"
        },
        "g": {
          "unit": "m/s**2",
          "desc": "gravitational acceleration (negative, up positive)"
        },
        "b": {
          "unit": "kg/s",
          "desc": "linear drag coefficient"
        },
        "v0": {
          "unit": "m/s",
          "desc": "initial velocity"
        },
        "t": {
          "unit": "s",
          "desc": "time"
        }
      },
      "assumptions": [
        "drag linear in speed",
        "constant gravity"
      ],
      "derivation": null,
      "lessons": [
        "freefall-drag"
      ],
      "citations": [],
