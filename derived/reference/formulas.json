    {
      "id": "shm-x-of-t",
      "name": "Position in simple harmonic motion",
      "domain": "mechanics",
      "regime": 2,
      "lhs": "x",
      "expr": "x0*cos(omega*t) + (v0/omega)*sin(omega*t)",
      "expr_srepr": "Add(Mul(Symbol('x0', real=True), cos(Mul(Symbol('omega', real=True), Symbol('t', real=True)))), Mul(Pow(Symbol('omega', real=True), Integer(-1)), Symbol('v0', real=True), sin(Mul(Symbol('omega', real=True), Symbol('t', real=True)))))",
      "latex": "x = x_{0} \\cos{\\left(\\omega t \\right)} + \\frac{v_{0} \\sin{\\left(\\omega t \\right)}}{\\omega}",
      "result_unit": "m",
      "variables": {
        "x0": {
          "unit": "m",
          "desc": "initial displacement"
