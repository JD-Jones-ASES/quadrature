{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quadrature/schemas/solution.schema.json",
  "title": "Quadrature solution object",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id", "title", "topic", "slug", "scenario", "regime", "constants",
    "assumptions", "algebra", "calculus", "proof", "units_check",
    "graphs", "formulas_used", "provenance"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title": { "type": "string" },
    "topic": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "scenario": { "type": "string" },
    "regime": { "enum": [1, 2, 3] },
    "constants": { "type": "object" },
    "initial_conditions": { "type": "object" },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim", "kind"],
        "properties": {
          "claim": { "type": "string" },
          "kind": { "const": "model" }
        }
      }
    },
    "algebra": {
      "type": "object",
      "additionalProperties": false,
      "required": ["steps", "result"],
      "properties": {
        "steps": { "type": "array", "items": { "$ref": "#/$defs/step" } },
        "result": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "unit", "value", "display"],
            "properties": {
              "label": { "type": "string" },
              "unit": { "type": "string" },
              "symbolic_latex": { "type": "string" },
              "value": { "type": "number" },
              "display": { "type": "string" }
            }
          }
        }
      }
    },
    "calculus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["steps"],
      "properties": {
        "steps": { "type": "array", "items": { "$ref": "#/$defs/step" } }
      }
    },
    "proof": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "heading", "checked_by", "holds", "detail", "checks"],
      "properties": {
        "kind": { "enum": ["equivalence", "governing", "integral"] },
        "heading": { "type": "string" },
        "checked_by": { "const": "sympy" },
        "holds": { "type": "boolean" },
        "detail": { "type": "string" },
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["key", "claim", "holds", "tier"],
            "properties": {
              "key": { "type": "string" },
              "claim": { "type": "string" },
              "holds": { "type": "boolean" },
              "tier": { "type": "string" }
            }
          }
        }
      }
    },
    "units_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checked_by", "holds"],
      "properties": {
        "checked_by": { "const": "sympy" },
        "holds": { "type": "boolean" }
      }
    },
    "sign_analysis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule", "segments"],
      "properties": {
        "rule": { "type": "string" },
        "segments": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["phase", "v_sign", "a_sign", "state"],
            "properties": {
              "phase": { "type": "string" },
              "t_range": { "type": "array", "items": { "type": "number" } },
              "t": { "type": "number" },
              "v_sign": { "type": "string" },
              "a_sign": { "type": "string" },
              "state": { "type": "string" }
            }
          }
        }
      }
    },
    "graphs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/graph" } },
    "misconception": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["claim", "refuted_by"],
      "properties": {
        "claim": { "type": "string" },
        "refuted_by": { "type": "string" }
      }
    },
    "formulas_used": { "type": "array", "items": { "type": "string", "pattern": "^[a-z0-9-]+$" } },
    "practice": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/practice_question" } },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["producer", "version", "sympy"],
      "properties": {
        "producer": { "type": "string" },
        "version": { "type": "string" },
        "sympy": { "type": "string" },
        "author": { "type": "string" },
        "created": { "type": "string" }
      }
    }
  },
  "$defs": {
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "latex"],
      "properties": {
        "label": { "type": "string" },
        "latex": { "type": "string" },
        "prose": { "type": "string" },
        "emphasis": { "type": "boolean" }
      }
    },
    "practice_question": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "asks", "prompt", "answer", "choices"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "asks": { "type": "string" },
        "prompt": { "type": "string" },
        "answer": {
          "type": "object",
          "additionalProperties": false,
          "required": ["value", "display", "unit"],
          "properties": {
            "value": { "type": "number" },
            "display": { "type": "string" },
            "unit": { "type": "string" },
            "symbolic_latex": { "type": "string" }
          }
        },
        "choices": {
          "type": "array",
          "minItems": 2,
          "contains": {
            "type": "object",
            "required": ["correct"],
            "properties": { "correct": { "const": true } }
          },
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["value", "display", "correct"],
            "properties": {
              "value": { "type": "number" },
              "display": { "type": "string" },
              "correct": { "type": "boolean" },
              "method": { "type": "string" },
              "misconception": { "type": "string" }
            }
          }
        },
        "algebra_steps": { "type": "array", "items": { "$ref": "#/$defs/step" } },
        "calculus_steps": { "type": "array", "items": { "$ref": "#/$defs/step" } }
      }
    },
    "series": {
      "type": "object",
      "additionalProperties": false,
      "required": ["t", "x", "v", "a", "t_max"],
      "properties": {
        "t": { "type": "array", "items": { "type": "number" } },
        "x": { "type": "array", "items": { "type": "number" } },
        "v": { "type": "array", "items": { "type": "number" } },
        "a": { "type": "array", "items": { "type": "number" } },
        "t_max": { "type": "number" }
      }
    },
    "graph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "mode"],
      "properties": {
        "kind": { "type": "string" },
        "mode": { "enum": ["static", "interactive", "sampled"] },
        "window": { "enum": ["landing", "fixed"] },
        "annotate": { "type": "array", "items": { "type": "string" } },
        "svg": { "type": "string" },
        "series": { "anyOf": [ { "$ref": "#/$defs/series" }, { "$ref": "#/$defs/area_series" }, { "$ref": "#/$defs/traj_series" }, { "$ref": "#/$defs/energy_series" }, { "$ref": "#/$defs/collision_series" }, { "$ref": "#/$defs/panel_series" } ] },
        "closed_form": { "type": "object", "additionalProperties": { "type": "string" } },
        "closed_form_params": { "type": "array", "items": { "type": "string" } },
        "u_label": { "type": "string" },
        "f_label": { "type": "string" },
        "g_label": { "type": "string" },
        "ke_label": { "type": "string" },
        "pe_label": { "type": "string" },
        "total_label": { "type": "string" },
        "consts": { "type": "object", "additionalProperties": { "type": "number" } },
        "panels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["key", "label", "unit"],
            "properties": {
              "key": { "type": "string" },
              "label": { "type": "string" },
              "unit": { "type": "string" },
              "accent": { "type": "boolean" }
            }
          }
        },
        "u0": { "type": "number" },
        "x_label": { "type": "string" },
        "y_label": { "type": "string" },
        "g": { "type": "number" },
        "frame": { "enum": ["ground", "orbit"] },
        "mu": { "type": "number" },
        "view_half": { "type": "number" },
        "reference": { "$ref": "#/$defs/traj_series" },
        "cursor": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "label", "min", "max", "default"],
          "properties": {
            "name": { "type": "string" },
            "label": { "type": "string" },
            "unit": { "type": "string" },
            "min": { "type": "number" },
            "max": { "type": "number" },
            "default": { "type": "number" }
          }
        },
        "params": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["min", "max", "default"],
            "properties": {
              "min": { "type": "number" },
              "max": { "type": "number" },
              "default": { "type": "number" }
            }
          }
        },
        "sweep": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "label", "values"],
          "properties": {
            "name": { "type": "string" },
            "label": { "type": "string" },
            "unit": { "type": "string" },
            "values": { "type": "array", "items": { "type": "number" } },
            "critical": { "type": "number" }
          }
        },
        "frames": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["value", "label", "series"],
            "properties": {
              "value": { "type": "number" },
              "label": { "type": "string" },
              "closed_form": { "type": "object", "additionalProperties": { "type": "string" } },
              "closed_form_params": { "type": "array", "items": { "type": "string" } },
              "series": { "oneOf": [ { "$ref": "#/$defs/series" }, { "$ref": "#/$defs/traj_series" } ] }
            }
          }
        }
      },
      "allOf": [
        {
          "if": { "required": ["mode"], "properties": { "mode": { "const": "sampled" } } },
          "then": { "required": ["sweep", "frames"] }
        },
        {
          "if": { "required": ["kind"], "properties": { "kind": { "const": "area" } } },
          "then": {
            "required": [
              "series", "closed_form", "closed_form_params", "params",
              "cursor", "u_label", "f_label", "g_label"
            ]
          }
        },
        {
          "if": { "required": ["kind"], "properties": { "kind": { "const": "trajectory" } } },
          "then": { "required": ["x_label", "y_label"] }
        },
        {
          "if": { "required": ["kind"], "properties": { "kind": { "const": "energy" } } },
          "then": {
            "required": [
              "series", "closed_form", "closed_form_params", "params",
              "cursor", "u_label", "ke_label", "pe_label"
            ]
          }
        },
        {
          "if": { "required": ["kind"], "properties": { "kind": { "const": "collision" } } },
          "then": {
            "required": [
              "series", "closed_form", "closed_form_params", "params",
              "cursor", "u_label", "consts"
            ]
          }
        },
        {
          "if": {
            "allOf": [
              { "properties": { "mode": { "not": { "const": "sampled" } } } },
              { "properties": { "kind": { "not": { "const": "area" } } } },
              { "properties": { "kind": { "not": { "const": "energy" } } } }
            ]
          },
          "then": { "required": ["series", "closed_form", "closed_form_params"] }
        }
      ]
    },
    "area_series": {
      "type": "object",
      "additionalProperties": false,
      "required": ["u", "f", "g", "u_max"],
      "properties": {
        "u": { "type": "array", "items": { "type": "number" } },
        "f": { "type": "array", "items": { "type": "number" } },
        "g": { "type": "array", "items": { "type": "number" } },
        "u_max": { "type": "number" }
      }
    },
    "traj_series": {
      "type": "object",
      "additionalProperties": false,
      "required": ["t", "x", "y", "t_max"],
      "properties": {
        "t": { "type": "array", "items": { "type": "number" } },
        "x": { "type": "array", "items": { "type": "number" } },
        "y": { "type": "array", "items": { "type": "number" } },
        "t_max": { "type": "number" }
      }
    },
    "energy_series": {
      "type": "object",
      "additionalProperties": false,
      "required": ["u", "ke", "pe", "u_max"],
      "properties": {
        "u": { "type": "array", "items": { "type": "number" } },
        "ke": { "type": "array", "items": { "type": "number" } },
        "pe": { "type": "array", "items": { "type": "number" } },
        "u_max": { "type": "number" }
      }
    },
    "collision_series": {
      "type": "object",
      "additionalProperties": false,
      "required": ["u", "v1f", "v2f", "u_max"],
      "properties": {
        "u": { "type": "array", "items": { "type": "number" } },
        "v1f": { "type": "array", "items": { "type": "number" } },
        "v2f": { "type": "array", "items": { "type": "number" } },
        "u_max": { "type": "number" }
      }
    },
    "panel_series": {
      "type": "object",
      "required": ["t", "t_max"],
      "properties": {
        "t": { "type": "array", "items": { "type": "number" } },
        "t_max": { "type": "number" }
      },
      "additionalProperties": { "type": "array", "items": { "type": "number" } }
    }
  }
}
