{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quadrature/schemas/formula.schema.json",
  "title": "Quadrature formula reference",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "formulas"],
  "properties": {
    "schema_version": { "type": "integer" },
    "formulas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "domain", "regime", "expr", "expr_srepr", "latex", "result_unit", "variables", "verified"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "name": { "type": "string" },
          "domain": { "enum": ["mechanics", "em", "thermo", "waves-optics", "modern"] },
          "regime": { "enum": [1, 2, 3] },
          "lhs": { "type": "string" },
          "expr": { "type": "string" },
          "expr_srepr": { "type": "string" },
          "latex": { "type": "string" },
          "result_unit": { "type": "string" },
          "variables": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": false,
              "required": ["unit"],
              "properties": {
                "unit": { "type": "string" },
                "desc": { "type": "string" }
              }
            }
          },
          "assumptions": { "type": "array", "items": { "type": "string" } },
          "derivation": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "required": ["relationship", "target", "variable"],
            "properties": {
              "relationship": { "enum": ["integral-of", "derivative-of", "derived-from"] },
              "target": { "type": "string", "pattern": "^[a-z0-9-]+$" },
              "variable": { "type": "string" }
            }
          },
          "lessons": { "type": "array", "items": { "type": "string" } },
          "citations": { "type": "array", "items": { "type": "string" } },
          "verified": {
            "type": "object",
            "additionalProperties": false,
            "required": ["units", "derivation"],
            "properties": {
              "units": { "type": "boolean" },
              "derivation": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}
