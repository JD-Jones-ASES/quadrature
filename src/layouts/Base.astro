---
import "@fontsource-variable/space-grotesk";
import "@fontsource/ibm-plex-mono";
import "katex/dist/katex.min.css";
import "../styles/portal.css";
import { withBase } from "../lib/withBase.js";

const { title = "Quadrature", description = "A dual algebra/calculus physics course where the verification system is the product." } = Astro.props;
const nav = [
  ["Home", "/"],
  ["Lessons", "/lessons/"],
  ["Reference", "/reference/"],
  ["Concept graph", "/reference/graph/"],
  ["Verification", "/verification/"],
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <header class="site-header">
      <div class="wrap">
        <a class="brand" href={withBase("/")}><span class="q">Q</span>uadrature</a>
        <nav class="nav">
          {nav.map(([label, href]) => <a href={withBase(href)}>{label}</a>)}
        </nav>
      </div>
    </header>
    <main>
      <div class="wrap">
        <slot />
      </div>
    </main>
    <footer class="site-footer">
      <div class="wrap">
        Algebra-based &amp; calculus-based physics, verified by SymPy. Code MIT · content CC BY-SA 4.0.
        AI-authored under an owner-designed verification system — the system is the safeguard.
      </div>
    </footer>
  </body>
</html>
