---
import Base from "../../layouts/Base.astro";
import { withBase } from "../../lib/withBase.js";
import { inline } from "../../lib/katex.js";
import { UNITS, ORDER } from "../../lib/lessonOrder.js";

const mods = import.meta.glob("../../../derived/**/*.solution.json", { eager: true });
const bySlug = Object.fromEntries(Object.values(mods).map((m) => [m.default.slug, m.default]));

const unitOf = Object.fromEntries(ORDER);
const orderIdx = Object.fromEntries(ORDER.map(([slug], i) => [slug, i]));

// Group lessons by unit (in UNITS order), each sorted by its position in ORDER. Drop empty units.
const groups = UNITS.map((u) => ({
  unit: u,
  lessons: Object.values(bySlug)
    .filter((l) => unitOf[l.slug] === u.id)
    .sort((a, b) => orderIdx[a.slug] - orderIdx[b.slug]),
})).filter((g) => g.lessons.length);

// Any lesson present in derived/ but not placed in the manifest → a resilient trailing group.
const placed = new Set(ORDER.map(([s]) => s));
const orphans = Object.values(bySlug).filter((l) => !placed.has(l.slug));
if (orphans.length) groups.push({ unit: { id: "more", title: "More lessons", blurb: "" }, lessons: orphans });

const total = Object.keys(bySlug).length;
const REGIME = { 1: "algebra is calculus, evaluated", 2: "calculus does what algebra cannot", 3: "algebra-only" };
---

<Base title="Lessons — Quadrature">
  <h1>Lessons</h1>
  <p class="muted lede">
    {total} deeply-built lessons, in course order — read top to bottom, or jump to a unit. New here? Start with
    the{" "}<a href={withBase("/guide/")}>guide</a>. Breadth lives in the{" "}
    <a href={withBase("/reference/")}>reference</a>. Each lesson is SymPy-verified end to end.
  </p>

  {groups.map((g) => (
    <section class="unit">
      <div class="unit-head">
        <h2 id={g.unit.id}>{g.unit.title}</h2>
        {g.unit.blurb && <p class="muted blurb">{g.unit.blurb}</p>}
      </div>
      <ul class="lessons">
        {g.lessons.map((l) => (
          <li>
            <a href={withBase(`/lessons/${l.slug}/`)}>
              <div class="row">
                <span class="title">{l.title}</span>
                <span class="badge regime" title={REGIME[l.regime]}>R{l.regime}</span>
              </div>
              <p class="scenario" set:html={inline(l.scenario)} />
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}

  <style>
    h1 { font-size: 1.9rem; }
    .lede { max-width: 48rem; }
    .unit { margin-top: 1.8rem; }
    .unit-head { border-bottom: 1px solid var(--line); padding-bottom: 0.3rem; margin-bottom: 0.8rem; }
    .unit-head h2 { font-size: 1.25rem; margin: 0; scroll-margin-top: 1rem; }
    .blurb { margin: 0.15rem 0 0; font-size: 0.9rem; }
    .lessons { list-style: none; padding: 0; display: grid; gap: 0.7rem; }
    .lessons a { display: block; background: var(--paper-2); border: 1px solid var(--line); border-radius: var(--radius); padding: 0.9rem 1.1rem; color: inherit; }
    .lessons a:hover { text-decoration: none; border-color: var(--accent); }
    .row { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; }
    .title { font-size: 1.05rem; font-weight: 600; color: var(--ink); }
    .badge.regime { flex: none; font-size: 0.72rem; padding: 0.1rem 0.45rem; }
    .scenario { color: var(--ink-2); margin: 0.35rem 0 0; font-size: 0.93rem; }
  </style>
</Base>
