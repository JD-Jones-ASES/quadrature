---
import { readFileSync } from "node:fs";
import Base from "../../layouts/Base.astro";
import SolutionPlayer from "../../islands/SolutionPlayer.svelte";
import { withBase } from "../../lib/withBase.js";
import { renderSolution } from "../../lib/view.js";

export function getStaticPaths() {
  const all = import.meta.glob("../../../derived/**/*.solution.json", { eager: true });
  return Object.values(all).map((m) => ({ params: { slug: m.default.slug }, props: { solution: m.default } }));
}

const { solution } = Astro.props;
const view = renderSolution(solution);
const svg = readFileSync(
  new URL("../../../derived/" + solution.graphs[0].svg, import.meta.url),
  "utf8"
);

const FRAMING = {
  1: "Regime 1 — the algebra is the calculus, evaluated. Step the algebra, step the calculus, and watch the algebra formula fall out of the integral. SymPy proves the two registers agree.",
  2: "Regime 2 — calculus does what algebra cannot. The acceleration isn't constant, so the algebra formulas don't apply; calculus is the only road in, and SymPy proves the closed form solves the equation of motion.",
  3: "Regime 3 — an algebra-only topic.",
};
---

<Base title={`${solution.title} — Quadrature`} description={solution.scenario}>
  <p class="crumb faint"><a href={withBase("/lessons/")}>Lessons</a> · {solution.topic}</p>
  <h1>{solution.title}</h1>
  <p class="muted intro">{FRAMING[solution.regime]}</p>

  <SolutionPlayer solution={view} client:visible />

  <section class="figure">
    <h2>The stacked graph, fully annotated</h2>
    <p class="muted">A static rendering (Matplotlib) at the default parameters — the interactive version is in
      the Graph tab above.</p>
    <div class="svgwrap" set:html={svg} />
  </section>

  <section class="links">
    <h2>Formulas used</h2>
    <p class="muted">Each links into the <a href={withBase("/reference/")}>reference</a> and the{" "}
      <a href={withBase("/reference/graph/")}>concept graph</a>:</p>
    <ul>
      {solution.formulas_used.map((id) => <li><code>{id}</code></li>)}
    </ul>
  </section>

  <style>
    h1 { font-size: 1.9rem; }
    .intro { max-width: 48rem; }
    .crumb { margin-bottom: 0.3rem; }
    .figure { margin-top: 2.5rem; }
    .svgwrap { max-width: 32rem; margin-top: 1rem; }
    .svgwrap :global(svg) { width: 100%; height: auto; }
    .links { margin-top: 2rem; }
    .links ul { list-style: none; padding: 0; display: flex; gap: 0.6rem; flex-wrap: wrap; }
    .links code { background: var(--paper-sunk); padding: 0.2rem 0.5rem; border-radius: 6px; }
  </style>
</Base>
