---
import { readFileSync } from "node:fs";
import Base from "../../layouts/Base.astro";
import SolutionPlayer from "../../islands/SolutionPlayer.svelte";
import { withBase } from "../../lib/withBase.js";
import { renderSolution } from "../../lib/view.js";
import { tex } from "../../lib/katex.js";
import { plain } from "../../lib/search.js";
import formulaData from "../../../derived/reference/formulas.json";

// Interlinking backbone (brief §8): each "formula used" chip hovers/focuses open its reference entry.
const formulaById = Object.fromEntries(formulaData.formulas.map((f) => [f.id, f]));

export function getStaticPaths() {
  const all = import.meta.glob("../../../derived/**/*.solution.json", { eager: true });
  return Object.values(all).map((m) => ({ params: { slug: m.default.slug }, props: { solution: m.default } }));
}

const { solution } = Astro.props;
const view = renderSolution(solution);
// Plain-text meta description: strip $…$ math, the adjacent formula-id tags, and **emphasis** so none of that
// authoring markup leaks into SEO/social snippets (the on-page scenario is rendered separately by the island).
const metaDescRaw = plain(solution.scenario);
const metaDesc = metaDescRaw.length > 157 ? metaDescRaw.slice(0, 156).replace(/\s+\S*$/, "") + "…" : metaDescRaw;
const svg = readFileSync(
  new URL("../../../derived/" + solution.graphs[0].svg, import.meta.url),
  "utf8"
);

const graph0 = solution.graphs[0];
const isArea = graph0.kind === "area";
const isTraj = graph0.kind === "trajectory";
const isLens = graph0.kind === "lens";
const fSym = (graph0.f_label ?? "").split("(")[0].trim();
const uSym = (graph0.u_label ?? "").split("(")[0].trim();

const FRAMING = {
  1: "Regime 1 — the algebra is the calculus, evaluated. Step the algebra, step the calculus, and watch the algebra formula fall out of the integral. SymPy proves the two registers agree.",
  2: isArea
    ? "Regime 2 — calculus does what algebra cannot. The integrand isn't constant, so no single algebra product gives the answer; the accumulated quantity is the area under the curve — and SymPy proves that area is exactly the closed-form result."
    : "Regime 2 — calculus does what algebra cannot. The acceleration isn't constant, so the algebra formulas don't apply; calculus is the only road in, and SymPy proves the closed form solves the equation of motion.",
  3: isArea
    ? "Regime 3 — an algebra-only domain, but the calculus underpinning is clean and worth seeing: the work is the area under the curve, ∫P dV. SymPy proves that area is exactly the memorized result — and that the constant-pressure case collapses to the rectangle."
    : isLens
    ? "Regime 3 — an algebra-only domain, and here the honest second register is geometry, not calculus: the ray diagram. The same image distance falls out of similar triangles, and SymPy proves the three principal-ray constructions agree — which IS the thin-lens equation."
    : "Regime 3 — an algebra-only topic.",
};

const figureHeading = isArea
  ? `The ${fSym}–${uSym} graph, fully annotated`
  : isTraj ? "The trajectory, fully annotated"
  : isLens ? "The ray diagram, fully annotated"
  : "The stacked graph, fully annotated";
const figureCaption = isArea
  ? `A static rendering (Matplotlib): the shaded area under ${fSym} is the accumulated integral ${graph0.g_label?.split("(")[0].trim()}, and the slope of ${graph0.g_label?.split("(")[0].trim()} is ${fSym}. The interactive version with a draggable cursor is in the Graph tab above.`
  : isTraj ? "A static rendering (Matplotlib) at the default launch — the path y vs x, with the apex and range marked. The interactive version with launch-angle and speed sliders is in the Graph tab above."
  : isLens ? "A static rendering (Matplotlib) at the default object distance — the three principal rays converging to the real, inverted image. The interactive version, with object-distance and height sliders, is in the Graph tab above."
  : "A static rendering (Matplotlib) at the default parameters — the interactive version is in the Graph tab above.";
---

<Base title={`${solution.title} — Quadrature`} description={metaDesc}>
  <p class="crumb faint"><a href={withBase("/lessons/")}>Lessons</a> · {solution.topic}</p>
  <h1>{solution.title}</h1>
  <p class="muted intro">{FRAMING[solution.regime]}</p>

  {/* client:load (not client:visible): the player IS the lesson and sits above the fold, and client:visible
      never hydrates in a headless preview that loads at a 0×0 viewport (the IntersectionObserver never fires),
      which blocks paint-verification. See docs/sessions. */}
  <SolutionPlayer solution={view} client:load />

  <section class="figure">
    <h2>{figureHeading}</h2>
    <p class="muted">{figureCaption}</p>
    <div class="svgwrap" set:html={svg} />
  </section>

  <section class="links">
    <h2>Formulas used</h2>
    <p class="muted">Hover a formula to preview its reference entry; click to open it in the{" "}
      <a href={withBase("/reference/")}>reference</a> (or the{" "}
      <a href={withBase("/reference/graph/")}>concept graph</a>):</p>
    <ul>
      {solution.formulas_used.map((id) => {
        const f = formulaById[id];
        return (
          <li class="fchip">
            <a class="fchip-link" href={withBase("/reference/#" + id)}>
              {f ? <span class="fname">{f.name}</span> : <code>{id}</code>}
            </a>
            {f && (
              <div class="fcard" role="tooltip">
                <div class="fmath" set:html={tex(f.latex)} />
                {f.assumptions?.length > 0 && (
                  <p class="fassume"><strong>Valid when:</strong> {f.assumptions.join("; ")}</p>
                )}
                <p class="fgo">Open in reference →</p>
              </div>
            )}
          </li>
        );
      })}
    </ul>
  </section>

  <style>
    h1 { font-size: 1.9rem; }
    .intro { max-width: 48rem; }
    .crumb { margin-bottom: 0.3rem; }
    .figure { margin-top: 2.5rem; }
    /* The static Matplotlib poster is baked light, so it sits on its own fixed-light "figure card"
       (--figure-paper does not flip in dark mode) — it reads as an intentional figure in both themes. */
    .svgwrap {
      max-width: 34rem; margin-top: 1rem; padding: 0.75rem;
      background: var(--figure-paper); border: 1px solid var(--figure-line); border-radius: var(--radius);
    }
    .svgwrap :global(svg) { width: 100%; height: auto; display: block; }
    .links { margin-top: 2rem; }
    .links ul { list-style: none; padding: 0; display: flex; gap: 0.6rem; flex-wrap: wrap; }
    /* §8 interlinking: a chip per formula used, with a hover/focus popover previewing the reference entry. */
    .fchip { position: relative; }
    .fchip-link { text-decoration: none; display: inline-block; }
    .fname, .fchip code { display: inline-block; background: var(--paper-sunk); padding: 0.25rem 0.6rem; border-radius: 6px; }
    .fchip-link:hover .fname, .fchip-link:focus-visible .fname, .fchip-link:hover code { background: var(--accent-soft); color: var(--accent); }
    .fcard {
      display: none; position: absolute; bottom: calc(100% + 0.5rem); left: 0; z-index: 20;
      min-width: 16rem; max-width: 24rem; padding: 0.7rem 0.85rem;
      background: var(--paper-2); border: 1px solid var(--line); border-radius: var(--radius);
      box-shadow: 0 6px 24px rgba(0, 0, 0, 0.18);
    }
    .fchip:hover .fcard, .fchip:focus-within .fcard { display: block; }
    .fcard .fmath { overflow-x: auto; margin: 0.1rem 0 0.4rem; }
    .fassume { font-size: 0.82rem; color: var(--ink-2); margin: 0.3rem 0 0; }
    .fgo { font-size: 0.78rem; color: var(--accent); margin: 0.45rem 0 0; }
  </style>
</Base>
